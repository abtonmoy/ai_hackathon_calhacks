# ── G1 jab track config. Source before running the g1/scripts/* files. ────────
# Verified tool chain: GMR -> whole_body_tracking csv_to_npz -> unitree_rl_lab.

export ROBOT="unitree_g1"                    # GMR robot flag
export MOTION_NAME="jab"                      # base name used across artifacts
export MOTION_FPS="30"                        # csv_to_npz --input_fps

# Where the external repos live (clone targets; see 00_setup.sh)
export GMR_DIR="${GMR_DIR:-$HOME/repos/GMR}"
export WBT_DIR="${WBT_DIR:-$HOME/repos/whole_body_tracking}"        # HybridRobotics
export RL_LAB_DIR="${RL_LAB_DIR:-$HOME/repos/unitree_rl_lab}"
export ISAACLAB_DIR="${ISAACLAB_DIR:-$HOME/repos/IsaacLab}"

# Our artifacts
export WORK="${WORK:-$HOME/g1_work}"          # all intermediate + final files land here
export PKL_OUT="${WORK}/${MOTION_NAME}.pkl"   # GMR output
export CSV_OUT="${WORK}/${MOTION_NAME}.csv"   # bridge output (csv_to_npz input)
export NPZ_OUT="${WORK}/${MOTION_NAME}.npz"   # trainer input

# unitree_rl_lab task + expected DoF
export TRACK_TASK="Unitree-G1-Tracking-No-State-Estimation"
export G1_DOF="29"                            # G1-29dof; set 23 if using the 23-dof asset

# A LAFAN1 g1 CSV to use as a column template for the pkl->csv bridge AND as a
# ready-made 'fight' reference to train on immediately. Fill after downloading.
export LAFAN1_TEMPLATE_CSV="${WORK}/lafan1_fight_sample.csv"

# Quaternion order GMR writes for the base rotation. Verify once; wxyz is typical.
export QUAT_ORDER="wxyz"

# ── Markerless capture (CHOSEN PATH): GVHMR monocular video -> SMPL -> GMR ─────
export GVHMR_DIR="${GVHMR_DIR:-$HOME/repos/GVHMR}"
export JAB_VIDEO="${JAB_VIDEO:-$WORK/jab_raw.mp4}"          # the phone clip of the jab
export GVHMR_PRED="${GVHMR_PRED:-$WORK/hmr4d_results.pt}"   # GVHMR output (-> gvhmr_to_robot.py)
