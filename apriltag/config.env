# ── AprilTag capture config. Source before running the apriltag/* scripts. ────
# Path: video -> 02_track.py (tag 6-DoF) -> 03_tags_to_g1_csv.py (G1 joint CSV)
#       -> ../scripts/12_to_npz.sh -> ../scripts/30_train.sh
# This BYPASSES GMR + SMPL: tag-pair relative rotations ARE the joint angles.

export AT_FAMILY="tag36h11"          # most robust AprilTag family
export AT_TAG_SIZE_M="0.06"          # printed tag black-square size, METERS (measure it!)
export AT_FPS="30"

# Camera intrinsics. Angles use RELATIVE rotations -> robust to rough intrinsics,
# so an FOV estimate is usually fine. Override with a real calibration if you have it.
export AT_HFOV_DEG="65"              # horizontal field of view of the phone/webcam
# export AT_FX=... AT_FY=... AT_CX=... AT_CY=...   # set these to skip FOV estimate

export AT_VIDEO="${AT_VIDEO:-$HOME/g1_work/jab_raw.mp4}"
export AT_POSES="${WORK:-$HOME/g1_work}/tag_poses.npz"      # 02 output
export AT_CSV="${WORK:-$HOME/g1_work}/jab.csv"              # 03 output (-> 12_to_npz.sh)

# Frame index of the calibration / guard pose (joint angles measured RELATIVE to it).
export AT_CALIB_FRAME="0"

# Reuse a LAFAN1 G1 CSV header so joint columns land in the exact right order.
export AT_TEMPLATE_CSV="${WORK:-$HOME/g1_work}/lafan1_fight_sample.csv"
